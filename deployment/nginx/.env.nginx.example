# Soketi Configuration
SOKETI_HOST=0.0.0.0
SOKETI_PORT=6001
SOKETI_WS_PORT=6001
SOKETI_METRICS_PORT=9601
SOKETI_METRICS_SERVER_PORT=9601
SOKETI_DEBUG=false

# Soketi App Configuration
SOKETI_DEFAULT_APP_ID=app-id
SOKETI_DEFAULT_APP_KEY=app-key
SOKETI_DEFAULT_APP_SECRET=app-secret
SOKETI_DEFAULT_APP_ENABLE_CLIENT_MESSAGES=true
SOKETI_DEFAULT_APP_ENABLED=true
SOKETI_DEFAULT_APP_MAX_CONNECTIONS=1000
SOKETI_DEFAULT_APP_MAX_BACKEND_EVENTS_PER_SEC=100
SOKETI_DEFAULT_APP_MAX_CLIENT_EVENTS_PER_SEC=100
SOKETI_DEFAULT_APP_MAX_READ_REQ_PER_SEC=100

# Soketi Config File (optional)
# SOKETI_CONFIG_PATH=./config.json

# Nginx Configuration
HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443
NGINX_HOST=soketi.example.com
NGINX_PORT=80

# Nginx Configuration Files (optional custom paths)
# NGINX_CONF_PATH=./nginx.conf
# NGINX_DEFAULT_CONF_PATH=./default.conf

# SSL/TLS Certificate Paths
# For development, use self-signed certificates
# For production, use Let's Encrypt or commercial CA certificates
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem
# SSL_CA_PATH=./certs/ca.pem

# Network Configuration
SOKETI_NETWORK_SUBNET=172.20.0.0/16

# Optional: Custom error pages
# NGINX_ERROR_PAGES=./error-pages
