# Caddy + Soketi Docker Compose Environment Variables
# Copy this file to .env and update with your values

# ============================================
# Soketi Configuration
# ============================================

# Server Configuration
SOKETI_HOST=0.0.0.0
SOKETI_PORT=6001
SOKETI_METRICS_SERVER_PORT=9601
SOKETI_DEBUG=false

# App Configuration
# IMPORTANT: Change these values in production!
SOKETI_DEFAULT_APP_ID=app-id
SOKETI_DEFAULT_APP_KEY=app-key
SOKETI_DEFAULT_APP_SECRET=app-secret

# App Settings
SOKETI_DEFAULT_APP_ENABLED=true
SOKETI_DEFAULT_APP_ENABLE_CLIENT_MESSAGES=true

# Connection Limits
SOKETI_DEFAULT_APP_MAX_CONNECTIONS=1000
SOKETI_DEFAULT_APP_MAX_BACKEND_EVENTS_PER_SEC=100
SOKETI_DEFAULT_APP_MAX_CLIENT_EVENTS_PER_SEC=100
SOKETI_DEFAULT_APP_MAX_READ_REQ_PER_SEC=100

# ============================================
# Caddy Configuration
# ============================================

# Admin API (for management)
CADDY_ADMIN=0.0.0.0:2019

# Domain (optional, for automatic HTTPS)
# Uncomment and set your domain for production
# DOMAIN=soketi.example.com

# ============================================
# Network Configuration
# ============================================

# Subnet for Docker network
SOKETI_NETWORK_SUBNET=172.20.0.0/16

# ============================================
# Port Mappings
# ============================================

# Caddy Ports
HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443

# Soketi Ports (for direct access)
SOKETI_WS_PORT=6001
SOKETI_METRICS_PORT=9601

# ============================================
# Volume Paths (optional)
# ============================================

# Custom config file path
# SOKETI_CONFIG_PATH=./config.json

# Custom Caddyfile path
# CADDYFILE_PATH=./Caddyfile

# Custom SSL certificates path
# SSL_CERTS_PATH=./certs
