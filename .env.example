# Soketi Configuration Example
# Copy this file to .env and update the values

# Redis Configuration
REDIS_PASSWORD=soketi
REDIS_PORT=6379

# Soketi Server Configuration
SOKETI_PORT=6001
SOKETI_METRICS_PORT=9601

# App Configuration
APP_ID=app-id
APP_KEY=app-key
APP_SECRET=app-secret

# Monitoring (optional)
GRAFANA_PASSWORD=admin
